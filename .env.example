# ── Database ────────────────────────────────────────────────────────────────
# Pooled connection (used at runtime via PgBouncer)
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"

# Direct connection (used by Prisma Migrate only)
DIRECT_URL="postgresql://user:password@host:5432/postgres"

# Prisma engine type
PRISMA_CLIENT_ENGINE_TYPE="library"

# ── Auth (NextAuth v5) ───────────────────────────────────────────────────────
# Canonical NextAuth v5 variable names (AUTH_URL / AUTH_SECRET).
# Run: openssl rand -base64 32   to generate AUTH_SECRET.
AUTH_URL="http://localhost:3000"
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# ── Supabase Realtime ────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
#
# NEXT_PUBLIC_* values are safe to expose to the browser (anon key only).
# SUPABASE_SERVICE_ROLE_KEY is server-side only — never expose to the client.
NEXT_PUBLIC_SUPABASE_URL="https://<project-id>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."
